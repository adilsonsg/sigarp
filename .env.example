APP_NAME=SIGARP
APP_VERSION=0.12.0-alpha1
APP_ENV=development
LOG_LEVEL=INFO
POSTGRES_DB=sigarp
POSTGRES_USER=sigarp
# Obrigatório no Docker Compose. Use segredo forte e não versione o .env.
POSTGRES_PASSWORD=
# Para execução fora do Compose, informe uma URL apropriada ao ambiente.
DATABASE_URL=postgresql+psycopg2://sigarp@localhost:5432/sigarp

PNCP_BASE_URL=https://pncp.gov.br/api/consulta
PNCP_TIMEOUT_SECONDS=30
PNCP_MAX_RETRIES=7
PNCP_BACKOFF_SECONDS=5
PNCP_USER_AGENT=SIGARP/0.12.0-alpha1 (IFMT)
PNCP_DOCUMENT_MAX_BYTES=50000000
PNCP_DOCUMENT_MAX_TEXT_CHARS=2000000
PNCP_DOCUMENT_MAX_PAGES=1000

# Lista JSON com identidades e somente o SHA-256 de tokens fortes.
# Vazio nega todas as rotas de dados protegidas.
AUTH_PRINCIPALS=[]
